aws_region    = "us-east-1"
project_name  = "card-transaction-system"
environment   = "prod"

lambda_memory  = 512
lambda_timeout = 30

bedrock_model_id = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
fraud_threshold  = 80

# ⚠️ MUDE ISSO EM PRODUÇÃO
jwt_secret              = "change-this-in-production-use-secure-key!!"
jwt_expiration_hours    = 24
orchestrator_timeout_seconds = 30
orchestrator_poll_interval_ms = 500

sqs_message_retention_seconds = 1209600
dynamodb_billing_mode         = "PAY_PER_REQUEST"
