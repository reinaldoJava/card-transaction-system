  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Temporal Activities Throughput (TPS)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "auto", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 3 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(temporal_activity_validate_seconds_count[1m]))", "legendFormat": "Validate Rules", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(temporal_activity_fraud_seconds_count[1m]))", "legendFormat": "Analyze Fraud", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(temporal_activity_status_seconds_count[1m]))", "legendFormat": "Update Status", "refId": "C" }
      ],
      "title": "Throughput por Atividade",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 11 },
      "id": 3,
      "title": "Latency (Seconds)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "rate(temporal_activity_validate_seconds_sum[1m]) / rate(temporal_activity_validate_seconds_count[1m])", "legendFormat": "Validate (Avg)", "refId": "A" },
        { "expr": "rate(temporal_activity_fraud_seconds_sum[1m]) / rate(temporal_activity_fraud_seconds_count[1m])", "legendFormat": "Fraud (Avg)", "refId": "B" }
      ],
      "title": "Latência Média",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "temporal_activity_validate_seconds_max", "legendFormat": "Validate (Max)", "refId": "A" },
        { "expr": "temporal_activity_fraud_seconds_max", "legendFormat": "Fraud (Max)", "refId": "B" }
      ],
      "title": "Picos de Latência (Max)",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 22 },
      "id": 6,
      "title": "Reliability & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 7,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "sum(rate(temporal_activity_fraud_seconds_count{error!=\"none\"}[5m])) / sum(rate(temporal_activity_fraud_seconds_count[5m])) * 100",
          "legendFormat": "Fraud Error Rate",
          "refId": "A"
        }
      ],
      "title": "Taxa de Erro Antifraude",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 25 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "expr": "sum by (error) (rate(temporal_activity_validate_seconds_count{error!=\"none\"}[5m]))",
          "legendFormat": "Validate Exceptions: {{error}}",
          "refId": "A"
        },
        {
          "expr": "sum by (error) (rate(temporal_activity_fraud_seconds_count{error!=\"none\"}[5m]))",
          "legendFormat": "Fraud Exceptions: {{error}}",
          "refId": "B"
        }
      ],
      "title": "Exceções Detalhadas",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["temporal", "saga", "payments"],
  "templating": { "list": [] },
